WECHAT_TARGET=HAO
AKSHARE_SYMBOL=全部
AKSHARE_NEWS_SOURCES=cls,sina,futu,em,ths
POLL_INTERVAL_SECONDS=3
NEWS_HISTORY_LIMIT=100
LOG_FILE=wxbot.log
STATE_FILE=wxbot_state.json
MAX_WECHAT_MESSAGE_LEN=1800

# OpenAI-compatible chat API
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_MODEL=Qwen/Qwen2.5-7B-Instruct
OPENAI_TIMEOUT_SECONDS=90
OPENAI_MAX_RETRIES=3

# Optional proxy for OpenAI requests only
OPENAI_HTTP_PROXY=http://127.0.0.1:7897
OPENAI_HTTPS_PROXY=http://127.0.0.1:7897
OPENAI_NO_PROXY=

# Daily GitHub + ClawHub digest
DAILY_DIGEST_TARGET=HAO
DAILY_REPORT_TIME=09:00
DAILY_DIGEST_LOOP_SECONDS=30
DAILY_DIGEST_STATE_FILE=daily_digest_state.json
GITHUB_TOP_N=5
GITHUB_LOOKBACK_DAYS=1
GITHUB_TOKEN=
CLAWHUB_TOP_N=5
CLAWHUB_QUERY_LIMIT=8
CLAWHUB_TOPIC_QUERIES=agent,github,search,automation,news,wechat
